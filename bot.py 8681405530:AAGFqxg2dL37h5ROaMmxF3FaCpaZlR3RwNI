import asyncio
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command

TOKEN = "YOUR_BOT_TOKEN"

bot = Bot(token=TOKEN)
dp = Dispatcher()

@dp.message(Command("start"))
async def start(message: types.Message):
    await message.answer("Бот іске қосылды ✅")

@dp.message(Command("profile"))
async def profile(message: types.Message):
    await message.answer("📋 Сіздің профиліңіз дайын емес")

@dp.message(Command("work"))
async def work(message: types.Message):
    await message.answer("💼 Сіз жұмысқа кірдіңіз!")

@dp.message(Command("bonus"))
async def bonus(message: types.Message):
    await message.answer("🎁 Күнделікті бонус алдыңыз!")

@dp.message(Command("shop"))
async def shop(message: types.Message):
    await message.answer("🛒 Магазин ашылды")

@dp.message(Command("help"))
async def help_cmd(message: types.Message):
    await message.answer(
        "📌 Командалар:\n"
        "/start - Ботты бастау\n"
        "/profile - Профиль\n"
        "/work - Жұмыс\n"
        "/bonus - Күнделікті бонус\n"
        "/shop - Магазин\n"
        "/help - Көмек"
    )

async def main():
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
